{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "kazashitego",
  "compatibility_date": "2026-05-05",
  "pages_build_output_dir": "out",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "kazashitego-db",
      "migrations_dir": "./migrations"
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
